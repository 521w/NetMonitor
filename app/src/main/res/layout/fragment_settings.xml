<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 协议过滤 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="协议过滤" android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_tcp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示 TCP 连接" android:checked="true" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_udp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示 UDP 连接" android:checked="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 状态过滤 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="状态过滤" android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_established"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ESTABLISHED (已建立)"
                    android:checked="true" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_listening"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LISTEN (监听中)"
                    android:checked="true" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_other"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="其他状态" android:checked="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 精确过滤 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精确过滤" android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="IP 地址过滤"
                    android:layout_marginBottom="8dp"
                    style=
                    "@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ip_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="端口号过滤"
                    android:layout_marginBottom="8dp"
                    style=
                    "@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_port_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="应用名过滤"
                    style=
                    "@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_app_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_filter"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重置"
                android:layout_marginEnd="8dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apply_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="应用过滤" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>